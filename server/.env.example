# PropChain server configuration (all optional in local dev)

# HTTP port (default 8899)
PORT=8899

# CORS allowlist, comma-separated origins. Defaults to "*" (open) when unset —
# set this before any public deploy, e.g.:
# CORS_ORIGINS=https://propchain.example.com,http://localhost:3000
CORS_ORIGINS=*

# Solana RPC endpoint (default devnet)
RPC_URL=https://api.devnet.solana.com

# POST /session throttle — protects the faucet, which only fires the first time
# a userKey is seen. Returning users and valid bearer tokens are never counted,
# so this caps NEW sign-ups per IP per window. Judges at a demo share one NAT'd
# IP: too low and the Nth judge sees a 429 that reads as "sign-in is broken".
# Defaults: 30 new sign-ups per 60 minutes.
# SESSION_THROTTLE_MAX=30
# SESSION_THROTTLE_WINDOW_MIN=60

# Privy server credentials. When BOTH are set:
#  * user wallets are created/signed in Privy's TEE instead of local keypairs;
#  * requests carrying an `x-privy-token` header are verified with
#    verifyAuthToken() and bound to the Privy user id.
# Leave unset for the local-dev fallback (session tokens + on-disk keypairs).
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Directory for persisted state: accounts (users.json), wallet keys
# (local-wallets.json), session tokens, funder state, fixtures archive, agent
# config. Defaults to the process cwd.
# ⚠️  PRODUCTION: this MUST be a PERSISTENT VOLUME. On an ephemeral host
# (Railway/Fly without a mounted volume) an unset or non-persistent DATA_DIR is
# wiped on every restart/redeploy — returning users then get brand-new wallets
# and lose their old accounts and bets. e.g. mount a volume at /data and set:
# DATA_DIR=/data
DATA_DIR=

# Recorded score feeds for the replay demo (default ../recordings). Ship/mount
# these in cloud so "Watch a live settlement" works during review.
RECORDINGS_DIR=

# 12th Man agent evaluation interval, ms (default 20000).
AGENT_TICK_MS=20000

# Funder wallet: either the secret key JSON array inline (cloud) ...
FUNDER_SECRET=
# ... or a path to a keypair file (default ./funder-keypair.json, auto-generated)
FUNDER_KEYPAIR=

# Use an existing pUSDC mint instead of creating one on first run
PUSDC_MINT=

# Path to the anchor IDL (default ../target/idl/propchain.json)
PROPCHAIN_IDL=
