# Keep the Docker build context lean and correct. node_modules must be excluded
# so the image installs fresh (a copied host node_modules would shadow the
# workspace links and defeat the whole point).
node_modules
**/node_modules
.git
app/.next
server/dist
# Drop the heavy Rust build artifacts, but KEEP the Anchor IDL + types the
# keeper reads at startup (target/idl/propchain.json). Mirrors .gitignore.
target/*
!target/idl
!target/types
.anchor
test-ledger
recordings
*.log
.DS_Store
