# --- shared ---
RPC_URL=https://api.devnet.solana.com
TXLINE_NETWORK=devnet

# --- keeper ---
# KEEPER_KEYPAIR=./keeper/keeper-keypair.json   # auto-generated if absent; fund with devnet SOL
# KEEPER_SECRET=                                # OR paste the keypair JSON array directly (cloud deploys)
# TXLINE_JWT=                                   # from keeper/txline-creds.json (cloud deploys)
# TXLINE_API_TOKEN=
# RECORDINGS_DIR=./recordings

# --- server (NestJS API — all wallets are server-side) ---
PORT=8899
PUSDC_MINT=DWF9ARTjTq3S2jMabyimsaXiVqGVHnVdp1XoRAh3s6Q8
# FUNDER_KEYPAIR=./server/funder-keypair.json   # auto-generated if absent; fund with devnet SOL
# FUNDER_SECRET=                                # OR paste the keypair JSON array directly (cloud deploys)
# Privy (optional — absent = local dev-wallet fallback). NEVER commit real values; set them in host env only.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- app (app/.env.local) ---
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_API_URL=http://localhost:8899
